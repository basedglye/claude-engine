{
  "name": "claude-engine-monorepo",
  "private": true,
  "version": "0.0.1",
  "description": "ClaudeEngine — an AI-native game engine and Claude Code plugin",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "node scripts/smoke.mjs",
    "harness": "npm run start --workspace @claude-engine/harness --",
    "assets:import": "npm run start --workspace @claude-engine/asset-pipeline --",
    "lint": "eslint .",
    "check:purity": "node scripts/check-purity.mjs"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "eslint": "^9.13.0",
    "typescript-eslint": "^8.11.0",
    "@types/node": "^22.9.0",
    "playwright": "^1.61.0"
  }
}
