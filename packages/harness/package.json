{
  "name": "@claude-engine/harness",
  "version": "0.0.1",
  "description": "Headless playtest harness — runs scenarios against the sim and emits structured JSON verdicts for agents",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
    "./browser": { "types": "./dist/browser.d.ts", "default": "./dist/browser.js" }
  },
  "bin": {
    "claude-engine-harness": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "@claude-engine/core": "*"
  },
  "peerDependencies": {
    "playwright": "^1.61.0"
  },
  "peerDependenciesMeta": {
    "playwright": { "optional": true }
  }
}
